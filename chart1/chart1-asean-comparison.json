{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "International Tourist Arrivals: Malaysia vs ASEAN Neighbors",
    "subtitle": "Malaysia competes closely with Singapore, but Thailand dominates the region",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "subtitleColor": "#666"
  },
  "width": "container",
  "height": 300,
  "data": {
    "url": "chart1/world_tourism_economy_data.csv"
  },
  "transform": [
    {"filter": "datum.tourism_arrivals != null"},
    {"filter": "datum.year >= 2010"},
    {
      "filter": {
        "field": "country",
        "oneOf": ["Malaysia", "Thailand", "Singapore", "Indonesia", "Philippines"]
      }
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "opacity": 0.15,
        "color": "#D3D3D333"
      },
      "encoding": {
        "x": {"datum": "2020"},
        "x2": {"datum": "2023"}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dx": 0,
        "dy": 10,
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#c0392b"
      },
      "encoding": {
        "x": {"datum": "2022"},
        "y": {"datum": 5000000},
        "text": {"value": "COVID-19: Borders Closed"}
      }
    },
    {
      "mark": {
        "type": "line",
        "point": false,
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "y": {
          "field": "tourism_arrivals",
          "type": "quantitative",
          "title": "Tourist Arrivals (millions)",
          "scale": {"zero": false},
          "axis": {
            "format": ".1s",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "title": "Country",
          "scale": {
            "domain": ["Malaysia", "Thailand", "Singapore", "Indonesia", "Philippines"],
            "range": ["#E8593C", "#3B8BD4", "#7F77DD", "#1D9E75", "#EF9F27"]
          },
          "legend": {
            "orient": "top-right",
            "labelFontSize": 12,
            "titleFontSize": 13
          }
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {
            "field": "tourism_arrivals",
            "type": "quantitative",
            "title": "Arrivals",
            "format": ",.0f"
          }
        ]
      }
    }
  ]
}