{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Malaysia's Tourism Revenue (1999-2023)",
    "subtitle": "Tourism generated RM84 billion in 2019 before COVID crashed the industry",
    "fontSize": 18,
    "subtitleFontSize": 14,
    "subtitleColor": "#666"
  },
  "width": "container",
  "height": 320,
  "data": {
    "url": "chart2/world_tourism_economy_data.csv"
  },
  "transform": [
    {"filter": "datum.country == 'Malaysia'"},
    {"filter": "datum.tourism_receipts != null"},
    {"filter": "datum.year >= 1999"}
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "opacity": 0.15,
        "color": "#D3D3D333"
      },
      "encoding": {
        "x": {"datum": 2020},
        "x2": {"datum": 2023}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dx": 0,
        "dy": 10,
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#b82929"
      },
      "encoding": {
        "x": {"datum": 2021.5},
        "y": {"datum": 15000000000},
        "text": {"value": "COVID-19 Impact"}
      }
    },
    {
      "mark": {
        "type": "area",
        "line": {
          "color": "#c0392b",
          "strokeWidth": 2.5
        },
        "color": {
          "gradient": "linear",
          "stops": [
            {"offset": 0, "color": "#c0392b"},
            {"offset": 1, "color": "#e1ccc7"}
          ]
        }
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year",
          "scale": {"zero": false, "domain": [1999, 2023]},
          "axis": {
            "format": "d",
            "values": [1999, 2003, 2007, 2011, 2015, 2019, 2023],
            "labelFontSize": 13,
            "titleFontSize": 14
          }
        },
        "y": {
          "field": "tourism_receipts",
          "type": "quantitative",
          "title": "Tourism Receipts (B = Billion)",
          "scale": {"zero": true},
          "axis": {
            "format": "~s",
            "labelExpr": "datum.value / 1000000000 + 'B'",
            "labelFontSize": 13,
            "titleFontSize": 14
          }
        },
        "tooltip": [
          {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
          {
            "field": "tourism_receipts",
            "type": "quantitative",
            "title": "Revenue (RM)",
            "format": ",.0f"
          }
        ]
      }
    }
  ]
}